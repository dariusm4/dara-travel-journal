# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.
#
# The app only needs ONE value: the URL of the local backend. All API keys
# (OpenAI / OpenWeather / Unsplash / exchangerate) live in `server/.env`, and
# every third-party call is proxied through the backend — the app bundle
# carries no secrets.
#
# Set this to match WHERE you run the app:
#   Web browser / iOS simulator : http://localhost:4000
#   Android emulator            : http://10.0.2.2:4000
#   Physical phone (Expo Go)    : http://<your-LAN-IP>:4000  (see the backend's startup log)
EXPO_PUBLIC_API_URL=http://localhost:4000
