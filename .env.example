# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.
# All values are exposed to the client (EXPO_PUBLIC_*). The rubric (criteria
# C + 14) explicitly accepts env vars; no backend deploy is required.

# Firebase (Project settings -> General -> Your apps -> SDK setup)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# External public APIs (free tiers)
EXPO_PUBLIC_OPENWEATHER_API_KEY=
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=
EXPO_PUBLIC_EXCHANGERATE_API_KEY=

# OpenAI (for the AI travel companion)
EXPO_PUBLIC_OPENAI_API_KEY=
